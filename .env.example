# StackDeploy — server config
# Mesh-VPN IP of this server
SERVER_IP=REPLACE_WITH_YOUR_MESH_VPN_IP

# Obsidian vault path on the host
OBSIDIAN_VAULT_PATH=/home/<user>/ObsidianVault

# Services
APPLICATION_TOKEN=REPLACE_WITH_APP_TOKEN
DB_ACCOUNT_PASSWORD=REPLACE_WITH_DB_PASSWORD
POSTGRES_PASSWORD=REPLACE_WITH_POSTGRES_PASSWORD

# Optional: local LLM add-on (only used if enabled in docker-compose.yml)
# OLLAMA_MODEL=qwen2.5:4b
# OLLAMA_NUM_CPU=4
# OLLAMA_MAX_LOADED_MODELS=1
# OLLAMA_NUM_PARALLEL=2
# MODEL_PATH=/models/Qwen3.5-9B-Coder-Q4_K_M.gguf
# CTX_SIZE=65536
